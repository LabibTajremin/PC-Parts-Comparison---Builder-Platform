# =============================================
# DATABASE (Neon PostgreSQL - free at neon.tech)
# =============================================
# Pooled connection (used by app at runtime)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/pcbuilder?sslmode=require

# Direct connection (used by Prisma migrations)
DIRECT_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/pcbuilder?sslmode=require

# =============================================
# REDIS (Upstash - free at upstash.com)
# =============================================
REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# =============================================
# AUTH
# =============================================
ADMIN_JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
ADMIN_JWT_EXPIRES_IN=24h

# =============================================
# AI (Anthropic)
# =============================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================
# APP
# =============================================
NODE_ENV=production
API_PORT=4000
FRONTEND_URL=https://your-app.vercel.app

# =============================================
# SCRAPER
# =============================================
SCRAPER_INTERVAL_HOURS=12
SCRAPER_TIMEOUT_MS=30000
